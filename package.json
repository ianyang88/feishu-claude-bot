{
  "name": "feishu-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Feishu (Lark) bot with WebSocket long connection",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "feishu-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
